[centos10-$basearch-baseos-rpms]
name = CentOS 10 (RPMs) - BaseOS
baseurl = https://mirror.stream.centos.org/10-stream/BaseOS/$basearch/os
enabled = 0
gpgcheck = 1
gpgkey = https://www.centos.org/keys/RPM-GPG-KEY-CentOS-Official-SHA256

[centos10-$basearch-appstream-rpms]
name = CentOS 10 (RPMs) - AppStream
baseurl = https://mirror.stream.centos.org/10-stream/AppStream/$basearch/os
enabled = 0
gpgcheck = 1
gpgkey = https://www.centos.org/keys/RPM-GPG-KEY-CentOS-Official-SHA256
