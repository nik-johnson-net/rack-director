[almalinux10-$basearch-baseos-rpms]
name = AlmaLinux 10.1 (RPMs) - BaseOS
baseurl = https://vault.almalinux.org/10.1/BaseOS/$basearch/os
enabled = 0
gpgcheck = 1
gpgkey = https://repo.almalinux.org/almalinux/RPM-GPG-KEY-AlmaLinux-10

[almalinux10-$basearch-appstream-rpms]
name = AlmaLinux 10.1 (RPMs) - AppStream
baseurl = https://vault.almalinux.org/10.1/AppStream/$basearch/os
enabled = 0
gpgcheck = 1
gpgkey = https://repo.almalinux.org/almalinux/RPM-GPG-KEY-AlmaLinux-10
